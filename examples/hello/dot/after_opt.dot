digraph "examples/hello/hello.c" {
  graph [pad=0.3, rankdir=TB, compound=true, overlap=false, nodesep=0.9, ranksep=1.3, splines=true];
  node [fontname="SF Pro Text Bold 10", fontsize=15];
  edge [fontname="SF Pro Text Bold 10", fontsize=15];
subgraph cluster_func_0 {
  shape="box";
  style="rounded, filled";
  fillcolor="#e3e3e3";
  color="#000000";
  penwidth=2;
  fontsize=20;
  fontname="SF Pro Text Bold 10";
  label="func";
  subgraph cluster_func_0_bb_0 {
    shape="box";
    style="rounded, filled";
    fillcolor="#a4a4a4";
    color="#000000";
    penwidth=2;
    fontsize=15;
    fontname="SF Pro Text Bold 10";
    label="label %1";
    node_0 [shape="box", style="rounded, filled", fillcolor="#6d95df", color="#000000", fontcolor="#000000", label="icmp"];
    node_1 [shape="box", style="rounded, filled", fillcolor="#6d95df", color="#000000", fontcolor="#000000", label="select"];
    node_2 [shape="box", style="rounded, filled", fillcolor="#6d95df", color="#000000", fontcolor="#000000", label="call"];
    node_3 [shape="box", style="rounded, filled", fillcolor="#6d95df", color="#000000", fontcolor="#000000", label="ret"];
    node_6 [shape="box", style="rounded, filled", fillcolor="#d66868", color="#000000", fontcolor="#000000", label="i32 %0"];
    node_7 [shape="box", style="rounded, filled", fillcolor="#d66868", color="#000000", fontcolor="#000000", label="i32 0"];
    node_8 [shape="box", style="rounded, filled", fillcolor="#d66868", color="#000000", fontcolor="#000000", label="ptr @str"];
    node_9 [shape="box", style="rounded, filled", fillcolor="#d66868", color="#000000", fontcolor="#000000", label="ptr @str.2"];
    node_10 [shape="box", style="rounded, filled", fillcolor="#d66868", color="#000000", fontcolor="#000000", label="ptr @puts"];
  }
}
