}
subgraph cluster_func_2 {
  shape="box";
  style="rounded, filled";
  fillcolor="#e3e3e3";
  color="#000000";
  penwidth=2;
  fontsize=20;
  fontname="SF Pro Text Bold 10";
  label="puts";
}
node_0 -> node_1 [color="#ff3636", weight=1000, penwidth=3, style="solid", constraint=true];
